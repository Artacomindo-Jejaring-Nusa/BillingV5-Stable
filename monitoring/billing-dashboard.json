{
  "title": "Billing System - Server Monitoring",
  "tags": ["billing", "server"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "panels": [
    {
      "id": 1,
      "title": "CPU Usage",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "100 - (avg by(instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[1m])) * 100)",
          "legendFormat": "CPU"
        }
      ],
      "options": {
        "reduceOptions": { "values": false, "calcs": ["mean"] },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Memory Usage",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
          "legendFormat": "RAM"
        }
      ],
      "options": {
        "reduceOptions": { "values": false, "calcs": ["mean"] },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Disk Usage",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "(1 - (node_filesystem_avail_bytes{mountpoint=\"/\", fstype!=\"\"} / node_filesystem_size_bytes{mountpoint=\"/\", fstype!=\"\"})) * 100",
          "legendFormat": "Disk"
        }
      ],
      "options": {
        "reduceOptions": { "values": false, "calcs": ["mean"] },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 80 },
              { "color": "red", "value": 95 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Uptime",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "time() - node_boot_time_seconds",
          "legendFormat": "Uptime"
        }
      ],
      "options": {
        "reduceOptions": { "values": false, "calcs": ["mean"] },
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        }
      }
    },
    {
      "id": 5,
      "title": "CPU Load Average",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        { "expr": "node_load1", "legendFormat": "Load 1m" },
        { "expr": "node_load5", "legendFormat": "Load 5m" },
        { "expr": "node_load15", "legendFormat": "Load 15m" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        }
      }
    },
    {
      "id": 6,
      "title": "Network Traffic",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        { "expr": "rate(node_network_receive_bytes_total{device!=\"lo\"}[1m])", "legendFormat": "{{device}} RX" },
        { "expr": "rate(node_network_transmit_bytes_total{device!=\"lo\"}[1m])", "legendFormat": "{{device}} TX" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        }
      }
    },
    {
      "id": 7,
      "title": "Docker Containers Status",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "count(container_last_seen{name=~\"billing.+|mysql|redis|nginx\"})",
          "legendFormat": "Running"
        }
      ],
      "options": {
        "reduceOptions": { "values": false, "calcs": ["mean"] },
        "orientation": "horizontal"
      }
    },
    {
      "id": 8,
      "title": "Container CPU Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 9, "x": 6, "y": 16 },
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{name=~\"billing.+|mysql|redis|nginx\"}[1m]) * 100",
          "legendFormat": "{{name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        }
      }
    },
    {
      "id": 9,
      "title": "Container Memory Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 9, "x": 15, "y": 16 },
      "targets": [
        {
          "expr": "container_memory_usage_bytes{name=~\"billing.+|mysql|redis|nginx\"}",
          "legendFormat": "{{name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        }
      }
    },
    {
      "id": 10,
      "title": "MySQL Connections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 24 },
      "targets": [
        { "expr": "mysql_global_status_threads_connected", "legendFormat": "Connected" },
        { "expr": "mysql_global_status_threads_running", "legendFormat": "Running" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        }
      }
    },
    {
      "id": 11,
      "title": "MySQL Queries per Second",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 24 },
      "targets": [
        { "expr": "rate(mysql_global_status_questions[1m])", "legendFormat": "Queries" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "qps",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        }
      }
    },
    {
      "id": 12,
      "title": "MySQL Thread Cache Hit Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 24 },
      "targets": [
        { "expr": "rate(mysql_global_status_threads_created[1m])", "legendFormat": "Threads Created" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        }
      }
    }
  ]
}
