# Database Master (Tulis/Write) - Mengarah ke Server Utama
DATABASE_URL="root:@tcp(localhost:3306)/billing_revaktor?charset=utf8mb4&parseTime=True&loc=Local"

# API Xendit Credentials
XENDIT_API_URL="https://api.xendit.co/v2/invoices"
XENDIT_API_KEY_JAKINET="your_xendit_api_key_here"
XENDIT_API_KEY_JELANTIK="your_xendit_api_key_here"

# Xendit Callbacks
XENDIT_CALLBACK_TOKEN_ARTACOMINDO="your_callback_token_here"
XENDIT_CALLBACK_TOKEN_JELANTIK="your_callback_token_here"

# Security & JWT
SECRET_KEY="your_jwt_secret_key_here"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=120
ENCRYPTION_KEY="your_fernet_encryption_key_here" # Fernet key (32 bytes base64 encoded URL safe)

# Maps API
MAPBOX_ACCESS_TOKEN="your_mapbox_token_here"

# AI & Monitoring (Opsional)
ALIBABA_CLOUD_API_KEY="your_alibaba_qwen_api_key_here"
TELEGRAM_BOT_TOKEN="your_telegram_bot_token_here"
TELEGRAM_CHAT_ID="your_telegram_chat_id_here"

# Watzap WhatsApp API (untuk Notifikasi Trouble Ticket ke Teknisi)
WATZAP_API_KEY="your_watzap_api_key_here"
WATZAP_NUMBER_KEY="your_watzap_number_key_here"
WATZAP_ACCESS_TOKEN="your_watzap_access_token_here"
